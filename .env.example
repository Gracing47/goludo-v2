# ============================================
# GOLUDO ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real values!

# ============================================
# FRONTEND (Vite)
# ============================================
# Thirdweb Client ID (get from https://thirdweb.com/dashboard)
VITE_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here

# DeepSeek API Key (for AI commentator)
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Contract Addresses (Coston2 Testnet) — CANONICAL $GO tokenomics contracts (G-024),
# verified on-chain via scripts/verify-onchain.mjs. Frontend (Vercel) and backend
# (Railway) MUST use the SAME pair or stakes bind to the wrong vault. Superseded:
#   - Gen 2 (native/early): GoToken 0x5078…4C13, LudoVault 0xa8d4…923a
#   - Gen 1 (docs/Archieve, never deployed): 0x9376…0688 / 0xd3EB…6E14
VITE_GOTOKEN_ADDRESS=0xfc1451906085D537160fF3789f87750321B16Ea1
VITE_LUDOVAULT_ADDRESS=0x24b32B913a99e7B5bC74FCb0C12e57ad123a3940

# Backend API URL (for production)
VITE_API_URL=http://localhost:3333

# ============================================
# BACKEND (Node.js)
# ============================================
# Server port
PORT=3333

# Server Signer Private Key (for EIP-712 payout signatures)
# WARNING: Use a dedicated wallet, NOT your main wallet!
SERVER_SIGNER_PRIVATE_KEY=0x_your_server_signer_private_key_here

# ============================================
# SMART CONTRACT DEPLOYMENT (Hardhat)
# ============================================
# WARNING: Never use your main wallet for deployment!
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key_here
